# ─── Backend ────────────────────────────────────────────────────────────────
# PostgreSQL connection — update host/port if not using Docker Compose
DATABASE_URL=postgresql+asyncpg://collab:collab@db:5432/collab_docs

# Comma-separated origins allowed to hit the API
# In production set this to your Vercel URL
CORS_ORIGINS=http://localhost:5173

# ─── Frontend ────────────────────────────────────────────────────────────────
# Backend API base URL used by the React app
# In production set this to your Railway backend URL
VITE_API_URL=http://localhost:8000
